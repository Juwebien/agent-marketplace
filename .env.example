# .env.example for a PNPM monorepo (packages: contracts, api, indexer, frontend)
# This is an example .env file for a marketplace AI agent on Base L2.
# Copy this to .env and fill in your actual values.
# Structure assumes shared env vars across packages, with package-specific ones prefixed (e.g., API_ for api package).

# General Environment Settings
NODE_ENV=development  # Environment: development, production, test
PORT=3000  # Default port for the API server (Fastify)

# Database (Prisma/PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/marketplace_db?schema=public  # Prisma connection string for PostgreSQL
PRISMA_SCHEMA_PATH=packages/api/prisma/schema.prisma  # Path to Prisma schema (adjust if needed)

# Redis
REDIS_URL=redis://localhost:6379  # Redis connection URL (for caching, sessions, etc.)
REDIS_PASSWORD=your_redis_password_here  # Optional Redis password if auth is enabled

# Blockchain Settings (Base L2 - Ethereum Layer 2)
CHAIN_ID=8453  # Base Mainnet Chain ID (use 84531 for Base Sepolia testnet)
RPC_URL_PRIMARY=https://mainnet.base.org  # Primary RPC URL (Alchemy recommended)
RPC_URL_ALCHEMY=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here  # Alchemy RPC URL
RPC_URL_INFURA=https://base-mainnet.infura.io/v3/your_infura_project_id_here  # Infura fallback RPC URL
RPC_URL_QUICKNODE=https://your-quicknode-endpoint.quiknode.pro/your_token_here/  # QuickNode fallback RPC URL

# Hardhat (for contracts package - smart contract deployment/testing)
HARDHAT_PRIVATE_KEY=your_wallet_private_key_here  # Private key for deploying contracts (never commit!)
HARDHAT_ETHERSCAN_API_KEY=your_etherscan_api_key_here  # API key for contract verification on Basescan
HARDHAT_DEPLOYER_ADDRESS=0xYourDeployerAddressHere  # Optional: Deployer wallet address

# Wagmi (for frontend package - web3 interactions)
WAGMI_PROJECT_ID=your_walletconnect_project_id_here  # WalletConnect Project ID for wagmi (if using)

# Pinata IPFS (for storing AI agent data, NFTs, etc.)
PINATA_API_KEY=your_pinata_api_key_here  # Pinata API key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here  # Pinata secret API key
PINATA_JWT=your_pinata_jwt_here  # Optional: Pinata JWT for authenticated requests
IPFS_GATEWAY=https://ipfs.io/ipfs/  # Default IPFS gateway (or your Pinata dedicated gateway)

# Stripe (for payments in the marketplace)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here  # Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here  # Stripe webhook signing secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here  # Stripe publishable key (for frontend)

# TRM Labs OFAC (for compliance screening, e.g., wallet sanctions checks)
TRM_API_KEY=your_trm_api_key_here  # TRM Labs API key for OFAC/sanctions screening
TRM_API_URL=https://api.trmlabs.com/public/v1/  # TRM API base URL (adjust if needed)

# JWT (RS256 for authentication)
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYourPrivateKeyHere\n-----END RSA PRIVATE KEY-----  # RSA private key for signing JWTs (multi-line supported)
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYourPublicKeyHere\n-----END PUBLIC KEY-----  # RSA public key for verifying JWTs
JWT_ISSUER=yourapp.com  # JWT issuer (e.g., your domain)
JWT_AUDIENCE=yourapp.com  # JWT audience
JWT_EXPIRATION=1h  # JWT expiration time (e.g., 1h, 24h)

# SIWE (Sign-In With Ethereum - integrated with JWT)
SIWE_NONCE_SECRET=your_siwe_nonce_secret_here  # Secret for generating/validating SIWE nonces
SIWE_SESSION_DURATION=86400  # SIWE session duration in seconds (e.g., 24 hours)

# API-Specific (Fastify 5 for api package)
API_SECRET=your_api_secret_here  # General secret for API (e.g., for hashing)
API_CORS_ORIGIN=http://localhost:3000  # Allowed CORS origin (update for production)

# Indexer-Specific (for blockchain event indexing)
INDEXER_START_BLOCK=0  # Starting block for indexing (e.g., genesis or last processed)
INDEXER_CONTRACT_ADDRESS=0xYourMarketplaceContractAddressHere  # Address of the main smart contract to index
INDEXER_POLL_INTERVAL=5000  # Polling interval in ms for new blocks/events

# Frontend-Specific
FRONTEND_BASE_URL=http://localhost:3000  # Base URL for frontend (used in API calls)
FRONTEND_API_ENDPOINT=/api  # Relative path to API from frontend

# Miscellaneous
LOG_LEVEL=info  # Logging level (debug, info, warn, error)
SENTRY_DSN=your_sentry_dsn_here  # Optional: Sentry DSN for error tracking
